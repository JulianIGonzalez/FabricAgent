# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Fabric Agent — Environment Variables Template
#
# Copy this file to ".env" and fill in real values.
# NEVER commit ".env" to source control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AD / Entra ID ───────────────────────────────────────────────────────
# The tenant (directory) that hosts your Fabric capacity.
FABRIC_TENANT_ID=your-tenant-id-here

# ── Service Principal credentials (recommended for automation / CI) ───────────
# Register an App in Entra ID → Certificates & Secrets → New client secret.
# Grant the app "Fabric API" permissions or add it as a Workspace member.
FABRIC_CLIENT_ID=your-app-client-id-here
FABRIC_CLIENT_SECRET=your-app-client-secret-here

# ── Auth flow selector ────────────────────────────────────────────────────────
# "service_principal"  → uses CLIENT_ID + CLIENT_SECRET (non-interactive, for automation)
# "device_code"        → interactive login in terminal (for delegated / user context)
FABRIC_AUTH_FLOW=service_principal

# ── Optional: Fabric API base URL (default shown) ────────────────────────────
# Only override if Microsoft publishes a new base URL.
# FABRIC_API_BASE_URL=https://api.fabric.microsoft.com/v1
